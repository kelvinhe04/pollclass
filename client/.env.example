# PollClass Frontend Environment Variables

# IMPORTANTE: Cambia esta IP a la dirección IP local de tu computadora
# Para averiguarla:
#   - Windows: Ejecuta "ipconfig" en cmd y busca "Dirección IPv4"
#   - Mac: Ejecuta "ipconfig getifaddr en0" en terminal
#   - Linux: Ejecuta "hostname -I" o "ip addr"

VITE_API_BASE_URL=http://192.168.1.100:3001