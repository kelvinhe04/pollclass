{
  "name": "pollclass",
  "version": "1.0.0",
  "description": "Aplicación de encuestas en vivo para el aula",
  "scripts": {
    "dev": "bun-run-all --parallel server client",
    "server": "cd server && bun run dev",
    "client": "cd client && bun run dev",
    "install-all": "bun install && cd server && bun install && cd ../client && bun install",
    "build:client": "cd client && bun run build",
    "setup:e2e": "bun x playwright install chromium",
    "test:e2e": "bun run playwright test",
    "test:e2e:headed": "bun run playwright test --headed",
    "test:e2e:ui": "bun run playwright test --ui",
    "test:e2e:report": "bun run playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "bun-run-all": "^1.2.1"
  }
}